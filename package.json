{
  "name": "chatbot-i-love-fresas-v2",
  "version": "0.1.0",
  "private": true,
  "description": "MVP foundation for reusable WhatsApp ordering chatbots for restaurants.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "telegram:dev": "tsx src/telegram-local.ts",
    "telegram:admin-id": "tsx src/telegram-admin-id.ts",
    "build": "tsc -p tsconfig.json",
    "build:dashboard": "npm run build --prefix dashboard",
    "build:all": "npm run build:dashboard && npm run build",
    "db:migrate": "npm run build && node dist/db/commands/migrate.js",
    "db:import-runtime": "npm run build && node dist/db/commands/import-runtime-store.js",
    "flowise:build-v3": "node scripts/build-flowise-v3-shadow.mjs",
    "flowise:validate-v3": "node scripts/validate-flowise-v3.mjs",
    "beta:local": "npm run build && node dist/local-beta.js",
    "qa:conversation": "npm run build && node dist/qa/conversation-regression.js",
    "qa:redteam": "npm run build && node dist/qa/red-team-attacks.js",
    "qa:chaos": "npm run build && node dist/qa/chaos-conversations.js",
    "qa:menu": "npm run build && node dist/qa/menu-real-catalog.js",
    "qa:personality": "npm run build && node dist/qa/personality-backtest.js",
    "qa:post-dispatch": "npm run build && node dist/qa/post-dispatch.js",
    "qa:required-options": "npm run build && node dist/qa/required-option-quantities.js",
    "qa:delivery-zones": "npm run build && node dist/qa/delivery-zones.js",
    "qa:barranquilla-neighborhoods": "npm run build && node dist/qa/barranquilla-neighborhood-validation.js",
    "qa:payment-proof": "npm run build && node dist/qa/payment-proof-validation.js",
    "qa:accounting-ledger": "npm run build && node dist/qa/accounting-ledger.js",
    "qa:dashboard-auth": "npm run build && node dist/qa/dashboard-auth.js",
    "qa:reset-conversations": "npm run build && node dist/qa/reset-conversations.js",
    "qa:realistic-waffle-orders": "npm run build && node dist/qa/realistic-waffle-orders.js",
    "qa:v3-contracts": "npm run build && node dist/qa/conversation-v3.js",
    "qa:telegram-webhook": "npm run build && node dist/qa/telegram-webhook.js",
    "qa:backtest": "npm run build && node dist/qa/integral-backtest.js",
    "qa:catalog-matrix": "npm run build && node dist/qa/catalog-matrix.js",
    "qa:ai-smoke": "npm run build && node dist/qa/ai-smoke.js",
    "qa:diversity-smoke": "npm run build && node dist/qa/diversity-smoke.js",
    "qa:gpt-engine": "npm run build && node dist/qa/gpt-engine.js",
    "qa:manual-failures": "npm run build && node dist/qa/manual-failures-index.js",
    "qa:openai-structural-mini": "npm run build && node dist/qa/openai-structural-mini.js",
    "test:bot-integration": "npm run build && node dist/qa/bot-integration-smoke.js",
    "test:dashboard-operational": "npm run build && node dist/qa/dashboard-operational-smoke.js",
    "test:runtime-store": "npm run build && node dist/qa/runtime-store-smoke.js",
    "test:catalog": "npm run build && node dist/catalog/catalog.test.js",
    "test:orchestrator": "npm run build && node dist/orchestrator/orchestrator.test.js",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pg": "^8.22.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
